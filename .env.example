# Copy to .env and fill values locally.
# Keep real keys out of git.

LLM_API_KEY=
IMAGE_API_KEY=
VIDEO_API_KEY=
VOICE_API_KEY=
MUSIC_API_KEY=

# Tencent Cloud TTS. Optional; use when replacing SiliconFlow TTS.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_TTS_REGION=ap-guangzhou
TENCENTCLOUD_TTS_APP_ID=

# SiliconFlow unified key. All configured SiliconFlow slots below use this.
SILICONFLOW_API_KEY=

# Optional overrides. Leave blank to use config/pipeline.siliconflow.yaml defaults.
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_LLM_STORY_MODEL=zai-org/GLM-5.2
SILICONFLOW_LLM_FAST_MODEL=zai-org/GLM-5.2
SILICONFLOW_LLM_VISION_MODEL=zai-org/GLM-4.5V
SILICONFLOW_IMAGE_MODEL=Tongyi-MAI/Z-Image
SILICONFLOW_IMAGE_FAST_MODEL=Tongyi-MAI/Z-Image-Turbo
SILICONFLOW_IMAGE_EDIT_MODEL=Qwen/Qwen-Image-Edit
SILICONFLOW_VIDEO_I2V_MODEL=Wan-AI/Wan2.2-I2V-A14B
SILICONFLOW_VIDEO_T2V_MODEL=Wan-AI/Wan2.2-T2V-A14B
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
SILICONFLOW_STT_MODEL=FunAudioLLM/SenseVoiceSmall
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Deployable FastAPI server. Change these before exposing the service on a server.
AI_MANGA_SECRET_KEY=change-this-long-random-string
AI_MANGA_DB_PATH=data/server/ai_manga.sqlite3
AI_MANGA_ADMIN_USERNAME=admin
AI_MANGA_ADMIN_PASSWORD=change-this-password
AI_MANGA_ADMIN_DISPLAY_NAME=系统管理员
AI_MANGA_ADMIN_MONTHLY_QUOTA=10000
AI_MANGA_MAX_ACTIVE_JOBS_PER_USER=2
AI_MANGA_MAX_ACTIVE_JOBS_TOTAL=8
